{
  "name": "adaptive-telemetry-dashboard",
  "version": "1.0.0",
  "description": "Multi-platform adaptive telemetry dashboard for FTC",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm --filter web dev\" \"pnpm --filter electron-app dev\"",
    "dev:host": "concurrently \"pnpm --filter web dev:host\" \"pnpm --filter electron-app dev\"",
    "build:web": "pnpm --filter web build",
    "build:electron": "pnpm --filter web build && pnpm --filter electron-app build",
    "build:mobile": "pnpm --filter web build && pnpm --filter mobile-app sync",
    "build:apk": "pnpm --filter mobile-app apk:debug",
    "install:apk": "pnpm --filter mobile-app apk:install",
    "open:android": "pnpm --filter mobile-app open:android",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.29.3",
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
